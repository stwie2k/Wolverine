<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <Button
                android:id="@+id/start_tracer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始观察"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/report_trace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始上报"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/start_tracer" />

            <Button
                android:id="@+id/start_act"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="启动一像素"
                android:textAllCaps="false"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/report_trace" />

            <Button
                android:id="@+id/dump"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="保活调用"
                android:textAllCaps="false"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/start_act" />

            <Button
                android:id="@+id/actFinish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关闭当前界面"
                android:textAllCaps="false"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/start_act" />

            <Button
                android:id="@+id/heartTest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="心跳测试"
                android:textAllCaps="false"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@id/actFinish" />

            <LinearLayout
                android:id="@+id/switchInit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/heartTest">

                <Switch
                    android:id="@+id/switchInitPut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="保活初始化开关"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/switchInitGet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="读取"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/switchSync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/switchInit">

                <Switch
                    android:id="@+id/switchSyncPut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="同步初始化"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/switchSyncGet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="读取"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/switchDouble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/switchSync">

                <Switch
                    android:id="@+id/switchDoublePut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="拉活能力x2"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/switchDoubleGet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="读取"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/switchIns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/switchDouble">

                <Switch
                    android:id="@+id/switchPullPut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="拉活开关"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/switchPullGet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="读取"
                    android:textAllCaps="false" />
            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>